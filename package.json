{
  "name": "fastroute-backend-supabase",
  "version": "2.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "lint:fix": "eslint src --fix",
    "lint": "eslint src",
    "typecheck": "node --check src/index.js && node --check src/routes/*.js && node --check src/services/*.js && node --check src/middleware/*.js && node --check src/lib/*.js",
    "test": "node --test test/*.test.js",
    "build": "npm run typecheck",
    "bootstrap:local": "npm install --no-audit --no-fund",
    "dev": "nodemon src/index.js",
    "dev:hot": "nodemon --watch src --watch .env --ext js,json,env --exec \"npm run build && node src/index.js\"",
    "dev:hot-deploy": "nodemon --watch . --ext js,json,env --exec \"npm run bootstrap:local && npm run build && node src/index.js\"",
    "start": "node src/index.js",
    "governance:impact": "node scripts/governance/analyze-impact.js"
  },
  "dependencies": {
    "@oliverbill/fastroute-domain": "^0.2.0",
    "@supabase/supabase-js": "^2.43.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "nodemon": "^3.1.4",
    "typescript-eslint": "^8.56.1"
  }
}
